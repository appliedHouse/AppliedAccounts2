@code {
    [Parameter]
    public EventCallback OnClick { get; set; }

    private string buttonStyle = "border:2px;";

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }
}

<button id="btn1-Clear"
        type="button"
        class="btn btn-sm w1 btn-primary"
        style="@buttonStyle"
        title="Clear Text"
        @onclick="HandleClick"
        @onmouseover="@(() => buttonStyle = "border:2px solid white; outline:2px solid white;")"
        @onmouseout="@(() => buttonStyle = "border:2px;")">
    <i class="bi bi-x-circle-fill"></i>
</button>