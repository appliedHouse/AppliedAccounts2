  <DataSets>
    <DataSet Name="ds_ExpenseGroup">
      <Query>
        <DataSourceName>ds_ExpenseGroup</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT [CB].[SheetNo],
       [CB].[Vou_No], 
       [CB].[Vou_Date], 
       [CB].[Ref_No], 
       [CB].[COA], 
       [A].[Title] AS [TitleCOA], 
       [CB].[Customer], 
       [C].[Title] AS [TitleCompany], 
       [CB].[Employee], 
       [E].[Title] AS [EmployeeName], 
       [CB].[Project], 
       [P].[Title] [ProjectName], 
       [CB].[Description], 
       [CB].[DR], 
       [CB].[CR]
FROM   [CashBook] AS [CB]
       LEFT JOIN [COA] [A] ON [A].[ID] = [CB].[COA]
       LEFT JOIN [Customers] [C] ON [C].[ID] = [CB].[Customer]
       LEFT JOIN [Employees] [E] ON [E].[ID] = [CB].[Employee]
       LEFT JOIN [Project] [P] ON [P].[ID] = [CB].[Project]</CommandText>
      </Query>
      <Fields>
        <Field Name="Sheet_No">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SheetNo</DataField>
        </Field>
        <Field Name="Vou_No">
