@page "/Accounts/Reports/Ledgers"
@attribute [Authorize]
@layout PageLayout

@using AppliedAccounts.Component.Libs
@using AppliedAccounts.Services

@inject IToastService ToastService
@inject PrintService ReportService
@inject GlobalService AppGlobal

@code {
	decimal LedgerBalance;

	protected override void OnInitialized()
	{
		LoadData();
		IsPageValid = true;
		if (Source is null) { IsPageValid = false; IsPageValidMessage += " Source is null"; }
	}

	protected override void OnAfterRender(bool firstRender)
	{
		LedgerBalance = 0.00M;
		if (firstRender)
		{

		}
	}


}

@if (IsPrinting)
{
	<div class="alert alert-primary d-flex align-items-center" role="alert">
		<div class="spinner-border text-primary me-2" role="status" aria-hidden="true"></div>
		<div>
			Loading printing data, please wait...
		</div>
	</div>
}

@if (MsgClass.Count > 0)
{
	<PageErrors Messages="@MsgClass" />
}



@if (IsPageValid)
{
	<div class="accordion mt-2" id="accordionLedger">
		<!-- General Ledger -->
		<div class="accordion-item mt-1">
			<h2 class="accordion-header">
				<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
					General Ledger
				</button>
			</h2>
			<div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionLedger">
				<div class="accordion-body">
					<div class="w-100">
						<div class="row g-2 p-1">
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateFrom" class="form-control" @bind-Value="MyModel.Date_From"></InputDate>
									<label for="DateFrom">From</label>
								</div>
							</div>
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateTo" class="form-control" @bind-Value="MyModel.Date_To"></InputDate>
									<label for="DateFrom">To</label>
								</div>
							</div>
							<div class="col-6">
								<MyDropDown id="ddAccounts"
											Label="Accounts"
											Value="@MyModel.COAID"
											ValueChanged="@((e) => AccountIDChanged(e))"
											Items="@MyModel.AccountList" />
							</div>
						</div>
						<div class="row g-2 p1-">
							<div>
								<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
									<div>
										<button class="btn btn-primary" @onclick="Refresh">Refresh</button>
									</div>
									<div style="display: flex; justify-content: flex-end;">
										@if (!IsPrinting)
										{
											<ReportingButtons ReturnValue="Print" ID="@MyModel.COAID" />
										}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- Supplier / Vendor / Client Ledger Ledger -->
		<div class="accordion-item mt-1">
			<h2 class="accordion-header">
				<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
					Supplier / Vendor / Client Ledger
				</button>
			</h2>
			<div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionLedger">
				<div class="accordion-body">
					<div class="w-100">
						<div class="row g-2 p-1">
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateFrom" class="form-control" @bind-Value="MyModel.DtFrom_Com"></InputDate>
									<label for="DateFrom">From</label>
								</div>
							</div>
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateTo" class="form-control" @bind-Value="MyModel.DtTo_Com"></InputDate>
									<label for="DateFrom">To</label>
								</div>
							</div>
							<div class="col-6">
                                <MyDropDown id="ddCompany"
                                            Label="Company"
                                            Value="@MyModel.CompanyID"
                                            ValueChanged="@((e) => CompanyIDChanged(e))"
                                            Items="@MyModel.CompanyList" />
							</div>
						</div>
					</div>
					<div class="row g-2 p1-">
						<div>
							<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
								<div>
									<button class="btn btn-primary" @onclick="Refresh">Refresh</button>
								</div>
								<div style="display: flex; justify-content: flex-end;">
									@if (!IsPrinting)
									{
										<ReportingButtons ReturnValue="PrintCompany" ID="@MyModel.CompanyID" />
									}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Employees Ledger -->
		<div class="accordion-item mt-1">
			<h2 class="accordion-header">
				<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
					Employee's Ledger
				</button>
			</h2>
			<div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionLedger">
				<div class="accordion-body">
					<div class="w-100">
						<div class="row g-2 p-1">
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateFrom" class="form-control" @bind-Value="MyModel.DtFrom_Emp"></InputDate>
									<label for="DateFrom">From</label>
								</div>
							</div>
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateTo" class="form-control" @bind-Value="MyModel.DtTo_Emp"></InputDate>
									<label for="DateFrom">To</label>
								</div>
							</div>
							<div class="col-6">
								<MyDropDown id="ddEmployee"
                                            Label="Employee"
                                            Value="@MyModel.EmployeeID"
                                            ValueChanged="@((e) => EmployeeIDChanged(e))"
                                            Items="@MyModel.EmployeeList" />
							</div>
						</div>
					</div>
					<div class="row g-2 p1-">
						<div>
							<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
								<div>
									<button class="btn btn-primary" @onclick="Refresh">Refresh</button>
								</div>
								<div style="display: flex; justify-content: flex-end;">
									@if (!IsPrinting)
									{
										<ReportingButtons ReturnValue="PrintEmployee" ID="@MyModel.EmployeeID" />
									}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Project Ledger -->
		<div class="accordion-item mt-1">
			<h2 class="accordion-header">
				<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
					Project's Ledger
				</button>
			</h2>
			<div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#accordionLedger">
				<div class="accordion-body">
					<div class="w-100">
						<div class="row g-2 p-1">
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateFrom" class="form-control" @bind-Value="MyModel.DtFrom_Prj"></InputDate>
									<label for="DateFrom">From</label>
								</div>
							</div>
							<div class="col-3">
								<div class="form-floating">
									<InputDate id="DateTo" class="form-control" @bind-Value="MyModel.DtTo_Prj"></InputDate>
									<label for="DateFrom">To</label>
								</div>
							</div>
							<div class="col-6">
								<MyDropDown id="ddProject"
                                            Label="Project"
                                            Value="@MyModel.ProjectID"
                                            ValueChanged="@((e) => ProjectIDChanged(e))"
                                            Items="@MyModel.ProjectList" />
							</div>
						</div>
					</div>
					<div class="row g-2 p1-">
						<div>
							<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
								<div>
									<button class="btn btn-primary" @onclick="Refresh">Refresh</button>
								</div>
								<div style="display: flex; justify-content: flex-end;">
									@if (!IsPrinting)
									{
										<ReportingButtons ReturnValue="PrintProject" ID="@MyModel.ProjectID" />
									}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

	</div>

}
else
{
	<div class="alert alert-danger" role="alert">
		<string>@IsPageValidMessage</string>
	</div>
}



<!--
	ADD THIS style for (center the pagination in Footer column.
	Do not Delete 13-09-25
-->
<style>
	.pagination {
		margin: 0px;
	}

	.accordion-button {
		height: 50px;
	}

	.accordion {
		padding-left: 15px;
		padding-right: 15px;
	}


</style>
