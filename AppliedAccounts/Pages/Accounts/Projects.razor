@page "/Accounts/Projects"

@namespace AppliedAccounts.Pages.Accounts

@using AppliedAccounts.Component.Libs
@using AppliedAccounts.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.Data

@inject GlobalService AppGlobal
@inject MessagesService MsgService
@inject IToastService ToastService


@code {

    private bool IsSubmitting { get; set; } = false;
    private string SubmitMessage { get; set; } = string.Empty;
    private bool EditMode { get; set; } = false;
}

<PageHeading Text="List of Projects"></PageHeading>
<ShowMessages MsgClass="MsgService.MsgClass"></ShowMessages>

@if (EditMode)
{

    <EditForm Model="MyModel" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />



        <div class="container myContainer flex-md-row ">

            <input @bind-value="MyModel.ID" hidden />

            <div class="row">
                <div class="col-md-4">
                    <div class="form-floating">
                    
                        <InputText id="code" class="form-control" @bind-Value="MyModel.Code" />
                        <label for="code">Code *</label>
                        <ValidationMessage For="@(() => MyModel.Code)" />
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating">
                    
                        <InputText id="title" class="form-control" @bind-Value="MyModel.Title" />
                        <label for="title">Title *</label>
                        <ValidationMessage For="@(() => MyModel.Title)" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <MyDropDown Id="ddClient"
                                Label="Client / Customer / Sub Account"
                                Value="@MyModel.Client"
                                ValueChanged="@CompanyIDChanged"
                                Items="@Clients" />
                </div>
                <div class="col-md-4">
                    <MyDropDown Id="ddEmployee"
                                Label="Project Manager"
                                Value="@MyModel.ProjectManager"
                                ValueChanged="@EmployeeIDChanged"
                                Items="@Employees" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-floating">
                    
                        <InputNumber id="budget" class="form-control" @bind-Value="MyModel.Budget" />
                        <label for="budget">Budget (Amount)</label>
                        <ValidationMessage For="@(() => MyModel.Budget)" />
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating">
                    
                        <InputNumber id="actualCost" class="form-control" @bind-Value="MyModel.ActualCost" />
                        <label for="actualCost">Actual Cost (Amount)</label>
                        <ValidationMessage For="@(() => MyModel.ActualCost)" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-floating">
                    
                        <InputDate id="startDate" class="form-control" @bind-Value="MyModel.StartDate" />
                        <label for="startDate">Start Date</label>
                        <ValidationMessage For="@(() => MyModel.StartDate)" />
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating">
                        <InputDate id="endDate" class="form-control" @bind-Value="MyModel.EndDate" />
                        <label for="endDate">End Date</label>
                        <ValidationMessage For="@(() => MyModel.EndDate)" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="form-floating">
                        <InputText id="location" class="form-control" @bind-Value="MyModel.Location" />
                        <label for="location">Location</label>
                        <ValidationMessage For="@(() => MyModel.Location)" />
                    </div>
                </div>
            </div>

            <div class="row">

                <div class="col-md-4">
                    <div class="form-floating">
                        <InputTextArea id="comments" class="form-control" rows="3" @bind-Value="MyModel.Comments" />
                        <label for="comments">Comments</label>
                        <ValidationMessage For="@(() => MyModel.Comments)" />
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating">
                        <InputTextArea id="terms" class="form-control" rows="3" @bind-Value="MyModel.Terms" />
                        <label for="terms">Terms & Conditions</label>
                        <ValidationMessage For="@(() => MyModel.Terms)" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-2">
                    <div class="form-check">
                        <InputCheckbox id="isActive" class="form-check-input" @bind-Value="MyModel.IsActive" />
                        <label class="form-check-label" for="isActive">Active Project</label>
                    </div>
                </div>

                <div class="col-2">
                    <div class="form-check">
                        <InputCheckbox id="isCompleted" class="form-check-input" @bind-Value="MyModel.IsCompleted" />
                        <label class="form-check-label" for="isCompleted">Completed</label>
                    </div>
                </div>

            </div>

        
        </div>

        <div class="container mt-2 mb-2 control-buttons">
        <div class="row ctrl">
            <div class="col d-flex gap-2">
                <button type="button" class="ctrl ctrl-save" @onclick="Save"><i class="bi bi-floppy2-fill"></i></button>
                <button type="button" class="ctrl ctrl-new" @onclick="Add"><i class="bi bi-plus-square-fill"></i></button>
                <button type="button" class="ctrl ctrl-back" @onclick="Back"><i class="bi bi-arrow-left-circle-fill"></i></button>
            </div>
        </div>
    </div>
    </EditForm>
}
else
{
    <div class="container">
        <table class="table-list">
            <thead>
                <tr>
                    <th style="width:10%">Code</th>
                    <th style="width:30%">Title</th>
                    <th style="width:50%">Comments</th>
                    <th style="width:10%" @onclick="Add"><i class="bi bi-folder-plus"></i></th>
                    
                </tr>
            </thead>
            <tbody>
                @foreach (DataRow Row in ProjectList.Rows)
                {
                    long _ID = Row.Field<long>("ID");

                    <tr>
                        <td class="center">@(Row.Field<string>("Code") ?? "")</td>
                        <td class="left">@(Row.Field<string>("Title") ?? "")</td>
                        <td class="left">@(Row.Field<string>("Comments") ?? "")</td>
                        <td>
                            <button class="btn-Edit" @onclick="@(()=>Edit(_ID))"><i class="bi bi-pencil"></i></button>
                            <button class="btn-Del" @onclick="@(()=>Delete(_ID))"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .row {
        margin-bottom: 15px;
    }
</style> 