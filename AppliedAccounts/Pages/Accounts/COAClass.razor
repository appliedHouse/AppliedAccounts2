@page "/Accounts/COAClass"
@attribute [Authorize]
@using AppliedAccounts.Component.Libs;
@using AppliedAccounts.Models;
@using AppliedAccounts.Services

@inject GlobalService AppGlobal
@inject IToastService ToastService


@code {
    protected override void OnInitialized()
    {
        MyModel = new(AppGlobal);
    }

    
}


<PageHeading Text="Class of Accounts"></PageHeading>


@* Page Errors Show *@
@if (MyModel.MsgClass.Count > 0)
{
    <PageErrors Messages="@MyModel.MsgClass"></PageErrors>
}

<EditForm Model="@MyModel">
    <div class="container">
        <InputNumber @bind-Value="@MyModel.Record.ID" placeholder="ID" id="ID" hidden></InputNumber>
        <div class="row">
            <div class="col-md-3">
                <div class="form-floating mb-3 txt">
                    <InputText @bind-Value="@MyModel.Record.Code" class="form-control" id="txtCode" placeholder="Voucher No" />
                    <label for="txtCode">Code</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-floating mb-3 txt">
                    <InputText @bind-Value="@MyModel.Record.Title" class="form-control" id="txtTitle" placeholder="Voucher No" />
                    <label for="txtTitle">Title of Account</label>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-2 mb-2 control-buttons">
        <div class="row ctrl">
            <div class="col d-flex gap-2">
                <button type="button" class="ctrl ctrl-save" @onclick="Save"><i class="bi bi-floppy2-fill"></i></button>
                <button type="button" class="ctrl ctrl-new" @onclick="Add"><i class="bi bi-plus-square-fill"></i></button>
                <button type="button" class="ctrl ctrl-back" @onclick="Back"><i class="bi bi-arrow-left-circle-fill"></i></button>
            </div>
        </div>

    </div>

    <div class="container">
        <table class="table-list">
            <thead class="tb-head">
                <tr class="tb-head-row">
                    <th style="width:20%">Code</th>
                    <th style="width:40%">Title</th>
                    <th style="width:20%" class="td-btn">
                        <button id="btnAdd" class="btn-Add" @onclick="Add"><i class="bi bi-plus-circle-fill"></i></button>
                    </th>
                </tr>
            </thead>
            <tbody class="tb-body">
                @foreach (COAClassRecord _Record in MyModel.Records)
                {
                    <tr class="tb-body-row">
                        <td>@_Record.Code</td>
                        <td class="tb-col-center">@_Record.Title</td>
                        
                        <td class="td-btn">
                            <button id="btnEdit" type="submit" class="btn-Edit" @onclick="(()=> Edit((long)_Record.ID))"><i class="bi bi-pencil-fill"></i></button>
                            <label style="padding-left:5px; padding-right:5px;"> | </label>
                            <button id="btnDel" type="submit" class="btn-Del" @onclick="(()=> Delete((long)_Record.ID))"><i class="bi bi-trash-fill"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>