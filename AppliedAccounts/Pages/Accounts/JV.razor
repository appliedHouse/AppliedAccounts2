@page "/Accounts/JV"
@page "/Accounts/JV/{Vou_No}"
@using AppliedAccounts.Component.ButtonsDictionery
@using AppliedAccounts.Component.Libs
@inject GlobalService AppGlobal
@inject PrintService ReportService
@inject IToastService ToastService


@code {

    public bool Stop = true;
    private string Message { get; set; } = "";
    private string VoucherNo { get; set; } = "";

    public bool ShowBtnSave()
    {
        // btnSave disable = 'true' / 'false'
        if (MyVoucher.Count == 0) { return true; }
        if (MyModel.Tot_DR != MyModel.Tot_CR) { return true; }
        if (MyModel.Tot_DR + MyModel.Tot_CR == 0) { return true; }

        return false;
    }

    protected override void OnInitialized()
    {
        MyModel = new(AppGlobal, Vou_No);

        if (MyModel == null) { IsPageValid = false; }
        if (MyModel!.Count > 0) { VoucherNo = MyModel.MyVoucher[0].Vou_No; }

        if (!IsPageValid)
        {
            Message = "Invalid Voucher Number";
        }

    }
}

<PageHeading Text="JOURNAL VOUCHER (JV)" />

@if (MyModel.MsgClass.Count > 0)
{
    <PageErrors Messages="MyModel.MsgClass"></PageErrors>
}

@if (IsPageValid)
{
    <div class="container">
        <div id="Transaction">

            <EditForm Model="@MyModel">
                <div class="container myContainer flex-md-row "></div>
                <input @bind-value="@MyModel.Transaction.ID" hidden />
                <input @bind-value="@MyModel.Transaction.Sr_No" hidden />
                <div class="row g-md-2 mb-2 my-2">
                    <div class="col-md-2">
                        <div class="form-floating">
                            <InputText disabled class="form-control" id="txtVouNo" placeholder="Voucher No" @bind-Value="MyModel.Transaction.Vou_No" disable>
                            </InputText>
                            <label for="txtVouNo">Voucher Number</label>

                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <InputText class="form-control" id="txtRefNo" placeholder="Reference number" @bind-Value="MyModel.Transaction.Ref_No">
                            </InputText>
                            <label for="txtRefNo">Reference Number</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <InputDate disabled="@CanEdit" class="form-control" id="dtVouDate" placeholder="Voucher Date" @bind-Value="MyModel.Transaction.Vou_Date">
                            </InputDate>
                            <label for="dtVouDate">Voucher Date</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <MyDropDown Id="ddAccount"
                                    Label="Accounts"
                                    Value="@MyModel.Transaction.COA"
                                    ValueChanged="@AccountIDChanged"
                                    Items="@MyModel.Accounts" />

                    </div>
                </div>
                <div class="row g-md-2 mb-2 my-2">
                    <div class="col-md-4">
                        <MyDropDown id="ddCompany"
                                    Label="Client / Customer / Sub Account"
                                    Value="@MyModel.Transaction.Company"
                                    ValueChanged="@((e) => CompanyIDChanged(e))"
                                    Items="@MyModel.Companies" />
                    </div>
                    <div class="col-md-4">
                        <MyDropDown id="ddEmployee"
                                    Label="Employee"
                                    Value="@MyModel.Transaction.Employee"
                                    ValueChanged="@((e) => EmployeeIDChanged(e))"
                                    Items="@MyModel.Employees" />

                        
                    </div>
                    <div class="col-md-4">
                        <MyDropDown id="ddProject"
                                    Label="Project"
                                    Value="@MyModel.Transaction.Project"
                                    ValueChanged="@((e) => ProjectIDChanged(e))"
                                    Items="@MyModel.Projects" />
                    </div>
                </div>
                <div class="row g-md-2 mb-2 my-2">
                    <div class="col-md-2">
                        <div class="form-floating">
                            <InputNumber class="form-control" id="txtDebit" placeholder="Debit Amount" @bind-Value="MyModel.Transaction.DR">
                            </InputNumber>
                            <label for="txtDebit">Debit</label>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <InputNumber class="form-control" id="txtCredit" placeholder="Credit Amount" @bind-Value="MyModel.Transaction.CR">
                            </InputNumber>
                            <label for="txtCredit">Credit</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <InputText class="form-control" id="txtDescription" placeholder="Description" @bind-Value="MyModel.Transaction.Description">
                            </InputText>
                            <label for="txtDescription">Description</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <InputText title="Non printable text for memories" class="form-control" id="txtDescription" placeholder="Comments" @bind-Value="MyModel.Transaction.Comments">
                            </InputText>
                            <label for="txtDescription">Comments</label>
                        </div>
                    </div>
                </div>

                <div class="container">
                    <div class="d-flex flex-row mb-3 filter position-relative">
                        <div class="p-2">
                            <button id="btn-New" type="button" class="btn btn-sm w1 btn-info" title="New" @onclick="MyModel.New">
                                <i class="bi bi-plus-square"></i>
                            </button>
                        </div>

                        <div class="p-2">

                            <Btn1_Add OnClick="MyModel.Save" />

                        </div>
                        <div class="p-2">
                            <Btn1_Save1 OnClick="(async ()=>await MyModel.SaveAllAsync())" VoucherNo="@VoucherNo" Visiable="@ShowBtnSave()" />
                        </div>

                        @if (MyModel.Count > 1)
                        {
                            <div class="btn-group p-2" role="group" aria-label="Navigation">
                                <button type="button" class="btn btn-sm w1 btn-light" title="Top" @onclick="MyModel.Top">
                                    <i class="bi bi-chevron-double-left"></i>
                                </button>

                                <button type="button" class="btn btn-sm w1 btn-light" title="Next" @onclick="MyModel.Next">
                                    <i class="bi bi-chevron-right"></i>
                                </button>

                                <button type="button" class="btn btn-sm w1 btn-light" title="Back" @onclick="MyModel.Back">
                                    <i class="bi bi-chevron-left"></i>
                                </button>

                                <button type="button" class="btn btn-sm w1 btn-light" title="Last" @onclick="MyModel.Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </button>
                            </div>
                            @if (MyModel.Tot_DR == MyModel.Tot_CR)
                            {
                                <div><ReportingButtons ReturnValue="Print" ID="@MyModel.Transaction.ID" /></div>
                            }

                        }

                        <!-- Float Back Button to the Right -->
                        <div class="p-2 ms-auto">
                            <button type="button" class="btn btn-sm w1 btn-warning" title="Back" @onclick="BackPage"><i class="bi bi-arrow-left-circle"></i></button>
                        </div>
                    </div>
                </div>



            </EditForm>
        </div>


    </div>

    <div class="TranList">
        <div class="container">
            <table class="table-list">
                <thead>
                    <tr>
                        <th style="width:10%">Sr. No.</th>
                        <th style="width:10%">Ref No</th>
                        <th style="width:27%">Account</th>
                        <th style="width:27%">Project</th>
                        <th style="width:10%">Debit</th>
                        <th style="width:10%">Credit</th>
                        <th style="width:6%">
                            <button @onclick="MyModel.New" class="btn ctrl ctrl-new"><i class="bi bi-file-plus"></i></button>
                        </th>
                    </tr>
                </thead>
                <tbody>

                    @if (MyModel.Count > 0)
                    {
                        @foreach (var item in MyModel.MyVoucher)
                        {

                            <tr>
                                <td>@item.Sr_No</td>
                                <td>@item.Ref_No</td>
                                <td class="left">@item.TitleAccount</td>
                                <td class="left">@item.TitleProject</td>
                                <td class="amount">@item.DR.ToString(Format.Digit)</td>
                                <td class="amount">@item.CR.ToString(Format.Digit)</td>

                                <td clas class="tb-col-left" s="td-btn">
                                    <button id="btnEdit" type="submit" class="btn-Edit" @onclick="(() => MyModel.Edit(item.Sr_No))"><i class="bi bi-pencil-fill"></i></button>
                                    <button id="btnDel" type="submit" class="btn-Del" @onclick="(() => MyModel.Remove(item.Sr_No))"><i class="bi bi-trash-fill"></i></button>
                                </td>

                            </tr>
                        }

                    }
                    else
                    {
                        <tr>
                            <td>
                                <button id="btnAdd">Add Transaction</button>
                            </td>
                        </tr>

                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td>TOTAL</td>
                        <td class="amount">@MyModel.Tot_DR.ToString(Format.Digit)</td>
                        <td class="amount">@MyModel.Tot_CR.ToString(Format.Digit)</td>
                        <td class="center">
                            <button @onclick="MyModel.New" class="btn ctrl ctrl-new"><i class="bi bi-file-plus"></i></button>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

else
{
    <div class="alert alert-danger" role="alert">@Message</div>

}

<!-- Browse Windows -->
<div class="modal fade" id="winBrowse" tabindex="-1" aria-labelledby="browseModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fs-5" id="browseModalLabel">@MyModel.BrowseClass.Heading</h5>
                <InputText @bind-Value="MyModel.BrowseClass.SearchText"
                           @oninput="MyModel.BrowseClass.InputHandler"
                           placeholder="Search..."
                           class="form-control" />

            </div>
            <div class="modal-body">
                <div class="container">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th style="width:15%">Code</th>
                                <th style="width:70%">Title</th>
                                <th style="width:15%">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in @MyModel.BrowseClass.GetBrowseList())
                            {
                                <tr>
                                    <td>@item.Code</td>
                                    <td>@item.Title</td>
                                    <td>
                                        <button class="btn btn-link" data-bs-dismiss="modal" @onclick="(e) => SelectedBrowse(item.ID)">
                                            <i class="bi bi-mouse"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        </div>
    </div>
</div>
